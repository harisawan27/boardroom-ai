# =============================================================================
# Boardroom AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# =============================================================================

# Google Gemini API key (required)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Comma-separated list of allowed CORS origins (optional, defaults to * in dev)
# Vite dev server runs on port 5173 by default.
# In production, set this to your Vercel frontend URL.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limit for POST /meeting endpoint (optional, default: 5/minute)
RATE_LIMIT=5/minute

# cd f:\boardroom-ai\backend
# python -m uvicorn main:app --port 8000 --reload

# cd f:\boardroom-ai\frontend
# npm run dev
